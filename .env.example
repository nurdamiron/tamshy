# =============================================================
#  TAMSHY — шаблон переменных окружения
#  Скопируй: cp .env.example .env.local  (для локалки)
#            cp .env.example .env.staging (для staging)
#  НЕ коммить файлы с реальными значениями!
# =============================================================

# ── APP ──────────────────────────────────────────────────────
APP_ENV=local
# local | staging | production
APP_PORT=4004
NEXT_PUBLIC_APP_URL=http://localhost:4004
ALLOWED_ORIGINS=http://localhost:4004
LOG_LEVEL=debug
# debug | info | warn | error

# ── DATABASE (PostgreSQL / Prisma) ───────────────────────────
# Local docker:   postgresql://tamshy:tamshy@127.0.0.1:5432/tamshy
# RDS (prod):     postgresql://USER:PASS@HOST:5432/tamshy?sslmode=require
DATABASE_URL=
DIRECT_URL=
# DIRECT_URL нужен Prisma при наличии connection pooler (PgBouncer / RDS Proxy)

# ── AUTH ─────────────────────────────────────────────────────
JWT_SECRET=
# Мин. 32 символа. Генерация: openssl rand -hex 32

# ── AWS S3 ───────────────────────────────────────────────────
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
# Без AWS_ACCESS_KEY_ID файлы сохраняются в public/uploads/ (локальный режим)
# Принудительно локальный режим:
UPLOAD_LOCAL_ONLY=
# 1 = всегда локально, пусто = авто-определение по наличию ключа

# ── SMS (Mobizon) ─────────────────────────────────────────────
MOBIZON_API_KEY=
# Пусто = dev-режим (OTP = 000000, SMS не отправляются)

# ── RATE LIMITING (Upstash Redis) ────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Пусто = rate limit отключён (только для local/staging)

# ── SUPABASE (не используется, оставлено для совместимости) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
