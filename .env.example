# ── PostgreSQL ─────────────────────────────────────────────
# Локально (docker): см. npm run db:local
DATABASE_URL="postgresql://tamshy:tamshy@127.0.0.1:5432/tamshy"
DIRECT_URL="postgresql://tamshy:tamshy@127.0.0.1:5432/tamshy"

# Прод / RDS: замени USER, PASSWORD, RDS_ENDPOINT, DB_NAME
# Часто нужен SSL:
# DATABASE_URL="postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/DB_NAME?sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/DB_NAME?sslmode=require"

# ── AWS S3 (загрузки POST /api/upload) ─────────────────────
AWS_REGION=eu-north-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Основное имя бакета (совместимо с AWS_S3_BUCKET):
AWS_S3_BUCKET_NAME=alashed-edu-storage

# После копирования в .env / .env.local выполни: npx prisma migrate deploy (или db push)
