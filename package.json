{
  "name": "tamshy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "APP_ENV=local PORT=4004 next dev -p 4004",
    "dev:staging": "APP_ENV=staging next dev -p 4004",
    "build": "prisma generate && next build",
    "build:staging": "APP_ENV=staging npm run build",
    "build:prod": "APP_ENV=production npm run build",
    "postinstall": "prisma generate",
    "start": "next start -p 4004",
    "lint": "next lint",
    "setup": "cp -n .env.example .env.local && echo '✓ .env.local создан. Заполни значения и запусти npm run dev'",
    "env:check": "npx tsx scripts/check-env.ts",
    "env:check:staging": "npx tsx scripts/check-env.ts --env staging",
    "env:check:prod": "npx tsx scripts/check-env.ts --env production",
    "seed": "npx tsx prisma/seed.ts",
    "download-media": "node scripts/download-media.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:deploy": "prisma generate && prisma db push && prisma db seed",
    "db:local": "bash scripts/local-db-up.sh && DATABASE_URL=postgresql://tamshy:tamshy@127.0.0.1:5432/tamshy DIRECT_URL=postgresql://tamshy:tamshy@127.0.0.1:5432/tamshy npm run db:deploy",
    "db:seed-local": "bash scripts/seed-local-db.sh"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1022.0",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.101.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.2",
    "next": "14.2.35",
    "next-intl": "^4.9.0",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "react-simple-maps": "^3.0.0",
    "swr": "^2.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-simple-maps": "^3.0.6",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
