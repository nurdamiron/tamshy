generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  phone        String    @unique
  name         String?
  role         Role      @default(STUDENT)
  createdAt    DateTime  @default(now())
  projects     Project[]
  votes        Vote[]
  otpCode      String?
  otpExpiry    DateTime?
  consentPd    Boolean   @default(false)
  consentPdAt  DateTime?
  consentSms   Boolean   @default(false)
  consentSmsAt DateTime?
}

model Project {
  id           String        @id @default(cuid())
  title        String
  description  String        @db.Text
  type         ProjectType
  fileUrl      String?
  videoUrl     String?
  thumbnailUrl String?
  status       ProjectStatus @default(PENDING)
  authorId     String
  author       User          @relation(fields: [authorId], references: [id])
  schoolName   String
  region       Region
  teacherName  String
  studentName  String?
  grade        Int
  juryScore    Int?
  juryComment  String?       @db.Text
  createdAt    DateTime      @default(now())
  votes        Vote[]
}

model Vote {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

enum Role {
  STUDENT
  TEACHER
  JURY
  ADMIN
}

enum ProjectType {
  VIDEO
  RESEARCH
  ART
  INVENTION
  APP
  OTHER
}

enum ProjectStatus {
  PENDING
  APPROVED
  REJECTED
  WINNER
}

// ── Contests ────────────────────────────────────────

model Contest {
  id          String            @id @default(cuid())
  title       String
  type        String            // ВИДЕОКОНКУРС, ЭССЕ, ФОТОКОНКУРС
  description String            @db.Text
  rules       String?           @db.Text
  status      ContestStatus     @default(ACTIVE)
  deadline    DateTime
  imageUrl    String?
  createdAt   DateTime          @default(now())
  documents   ContestDocument[]
  submissions ContestSubmission[]
}

model ContestDocument {
  id        String  @id @default(cuid())
  contestId String
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  title     String
  fileUrl   String
  fileSize  String
  fileType  String  // PDF, DOCX
}

model ContestSubmission {
  id          String           @id @default(cuid())
  contestId   String
  contest     Contest          @relation(fields: [contestId], references: [id])
  fullName    String
  birthDate   String
  email       String
  phone       String
  institution String
  region      Region
  fileUrl     String?
  status      SubmissionStatus @default(NEW)
  createdAt   DateTime         @default(now())
}

// ── Materials ───────────────────────────────────────

model Material {
  id          String           @id @default(cuid())
  title       String
  description String           @db.Text
  format      String           // PDF, DOCX, MP4, PPTX, XLSX
  fileUrl     String
  fileSize    String
  imageUrl    String?
  type        MaterialType
  audience    MaterialAudience
  year        Int
  downloads   Int              @default(0)
  views       Int              @default(0)
  featured    Boolean          @default(false)
  createdAt   DateTime         @default(now())
}

// ── News ────────────────────────────────────────────

model News {
  id         String       @id @default(cuid())
  title      String
  content    String       @db.Text
  category   NewsCategory
  imageUrl   String?
  fileUrl    String?
  photoCount Int?
  viewCount  Int          @default(0)
  createdAt  DateTime     @default(now())
}

// ── Contact & Newsletter ────────────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  topic     String
  message   String   @db.Text
  fileUrl   String?
  createdAt DateTime @default(now())
}

model NewsletterSub {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// ── Enums ───────────────────────────────────────────

enum ContestStatus {
  ACTIVE
  COMPLETED
}

enum SubmissionStatus {
  NEW
  REVIEWING
  ACCEPTED
  REJECTED
}

enum MaterialType {
  METHODICAL
  BOOKLET
  PRESENTATION
  VIDEO
}

enum MaterialAudience {
  SCHOOL
  STUDENT
  TEACHER
}

enum NewsCategory {
  NEWS
  REPORT
  PHOTO
  VIDEO
}

enum Region {
  ASTANA
  ALMATY
  SHYMKENT
  AKTOBE
  KARAGANDA
  MANGYSTAU
  TURKESTAN
  ZHAMBYL
  ALMATY_REGION
  ATYRAU
  AKTAU
  PAVLODAR
  SEMEY
  TALDYKORGAN
  KYZYLORDA
  TARAZ
  PETROPAVLOVSK
  ORAL
  KOSTANAY
}
