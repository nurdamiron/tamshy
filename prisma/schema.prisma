generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String              @id @default(cuid())
  email           String?             @unique
  phone           String?             @unique
  name            String?
  role            Role                @default(STUDENT)
  tokenVersion    Int                 @default(0)
  createdAt       DateTime            @default(now())
  projects        Project[]
  votes           Vote[]
  submissions     ContestSubmission[]
  otpCode         String?
  otpExpiry       DateTime?
  consentPd       Boolean             @default(false)
  consentPdAt     DateTime?
  consentEmail    Boolean             @default(false)
  consentEmailAt  DateTime?
  // Legacy — оставлено для совместимости
  consentSms      Boolean             @default(false)
  consentSmsAt    DateTime?
}

model Project {
  id           String        @id @default(cuid())
  title        String
  description  String        @db.Text
  type         ProjectType
  fileUrl      String?
  videoUrl     String?
  thumbnailUrl String?
  status       ProjectStatus @default(PENDING)
  authorId     String
  author       User          @relation(fields: [authorId], references: [id])
  schoolName   String
  region       Region
  teacherName  String
  studentName  String?
  grade        Int
  teamMembers  Json?         // [{name: string, grade: number}] — доп. участники
  summary      String?       @db.Text // Краткая аннотация
  juryScore    Int?
  juryComment  String?       @db.Text
  createdAt    DateTime      @default(now())
  votes        Vote[]

  // ── Qazsu integration ────────────────────────────────
  sourceSystem        SourceSystem      @default(DIRECT)
  sourceCampaign      String?           // напр. "tamshy-2026"
  basin               WaterBasin?
  waterObjectId       String?           // внешний идентификатор объекта Qazsu
  waterObject         WaterObject?      @relation(fields: [waterObjectId], references: [id], onDelete: SetNull)
  problemType         WaterProblemType?
  qazsuRefUrl         String?           // deeplink на объект в Qazsu
  qazsuSnapshot       Json?             // снэпшот контекста на момент подачи
  publishToQazsu      Boolean           @default(false)
  publishedToQazsuAt  DateTime?

  // Индексы создаются через scripts/create-indexes.sql (права DBA нужны в prod RDS)
}

// Справочник водных объектов (бассейн, река, озеро, водохранилище, канал).
// Является master-source для интеграции Qazsu↔Tamshy. Может пополняться seed/admin.
model WaterObject {
  id          String      @id // напр. "ili-river", внешний id из Qazsu
  name        String
  nameKz      String?
  nameEn      String?
  basin       WaterBasin
  type        WaterObjectType
  region      Region?
  description String?     @db.Text
  qazsuUrl    String?
  createdAt   DateTime    @default(now())
  projects    Project[]
}

model Vote {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  // Индексы создаются через scripts/create-indexes.sql (права DBA нужны в prod RDS)
}

enum Role {
  STUDENT
  TEACHER
  JURY
  ADMIN
}

enum ProjectType {
  VIDEO
  RESEARCH
  ART
  INVENTION
  APP
  OTHER
}

enum ProjectStatus {
  PENDING
  APPROVED
  REJECTED
  WINNER
}

// ── Contests ────────────────────────────────────────

model Contest {
  id          String            @id @default(cuid())
  title       String
  type        String            // ВИДЕОКОНКУРС, ЭССЕ, ФОТОКОНКУРС
  description String            @db.Text
  rules       String?           @db.Text
  status      ContestStatus     @default(ACTIVE)
  deadline    DateTime
  imageUrl    String?
  createdAt   DateTime          @default(now())
  documents   ContestDocument[]
  submissions ContestSubmission[]
}

model ContestDocument {
  id        String  @id @default(cuid())
  contestId String
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  title     String
  fileUrl   String
  fileSize  String
  fileType  String  // PDF, DOCX
}

model ContestSubmission {
  id          String           @id @default(cuid())
  contestId   String
  contest     Contest          @relation(fields: [contestId], references: [id])
  userId      String?
  user        User?            @relation(fields: [userId], references: [id])
  fullName    String
  birthDate   String
  email       String
  phone       String
  institution String
  region      Region
  fileUrl     String?
  status      SubmissionStatus @default(NEW)
  createdAt   DateTime         @default(now())
}

// ── Materials ───────────────────────────────────────

model Material {
  id          String           @id @default(cuid())
  title       String
  description String           @db.Text
  format      String           // PDF, DOCX, MP4, PPTX, XLSX
  fileUrl     String
  fileSize    String
  imageUrl    String?
  type        MaterialType
  audience    MaterialAudience
  year        Int
  downloads   Int              @default(0)
  views       Int              @default(0)
  featured    Boolean          @default(false)
  createdAt   DateTime         @default(now())

  // Индексы создаются через scripts/create-indexes.sql (права DBA нужны в prod RDS)
  // @@index([type, audience])
  // @@index([featured])
  // @@index([downloads(sort: Desc)])
}

// ── News ────────────────────────────────────────────

model News {
  id         String       @id @default(cuid())
  title      String
  content    String       @db.Text
  category   NewsCategory
  imageUrl   String?
  fileUrl    String?
  photoCount Int?
  viewCount  Int          @default(0)
  createdAt  DateTime     @default(now())

  // Индексы создаются через scripts/create-indexes.sql (права DBA нужны в prod RDS)
  // @@index([category, createdAt(sort: Desc)])
}

// ── Contact & Newsletter ────────────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  topic     String
  message   String   @db.Text
  fileUrl   String?
  createdAt DateTime @default(now())
}

model NewsletterSub {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// ── Enums ───────────────────────────────────────────

enum ContestStatus {
  ACTIVE
  COMPLETED
}

enum SubmissionStatus {
  NEW
  REVIEWING
  ACCEPTED
  REJECTED
}

enum MaterialType {
  METHODICAL
  BOOKLET
  PRESENTATION
  VIDEO
}

enum MaterialAudience {
  SCHOOL
  STUDENT
  TEACHER
}

enum NewsCategory {
  NEWS
  REPORT
  PHOTO
  VIDEO
}

enum Region {
  ASTANA
  ALMATY
  SHYMKENT
  AKTOBE
  KARAGANDA
  MANGYSTAU
  TURKESTAN
  ZHAMBYL
  ALMATY_REGION
  ATYRAU
  AKTAU
  PAVLODAR
  SEMEY
  TALDYKORGAN
  KYZYLORDA
  TARAZ
  PETROPAVLOVSK
  ORAL
  KOSTANAY
}

// ── Qazsu integration enums ─────────────────────────

enum SourceSystem {
  DIRECT       // подача напрямую через Tamshy
  QAZSU        // переход из qazsu.gov.kz
  PARTNER      // другие партнерские источники
}

// 8 водохозяйственных бассейнов Казахстана (источник: BVI / qazsu.gov.kz)
enum WaterBasin {
  URAL_CASPIAN      // Жайык-Каспийский
  ARAL_SYRDARYA     // Арало-Сырдарьинский
  BALKHASH_ALAKOL   // Балхаш-Алакольский
  IRTYSH            // Ертіс
  ESIL              // Есіль / Ишимский
  NURA_SARYSU       // Нура-Сарысуский
  TOBOL_TURGAY      // Тобол-Тургайский
  SHU_TALAS         // Шу-Таласский
}

enum WaterObjectType {
  RIVER             // река
  LAKE              // озеро
  RESERVOIR         // водохранилище
  CANAL             // канал
  GROUNDWATER       // подземный водоносный горизонт
  GLACIER           // ледник
  OTHER
}

enum WaterProblemType {
  WATER_QUALITY     // качество воды, загрязнение
  WATER_SCARCITY    // дефицит, маловодье
  IRRIGATION        // эффективность ирригации
  LOSSES            // потери в распределительной сети
  MONITORING        // мониторинг, citizen science
  EDUCATION         // экопросвещение, культура водосбережения
  TRANSBOUNDARY     // трансграничные водные ресурсы
  FLOOD             // паводки, ранее предупреждение
  GROUNDWATER       // подземные воды
  INNOVATION        // приложения, IoT, ML, дашборды
  OTHER
}
